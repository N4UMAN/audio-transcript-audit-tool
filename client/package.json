{
  "name": "sheets-audit-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:server": "tsc --project src/server/tsconfig.server.json --outDir dist",
    "build:all": "npm run build && npm run build:server",
    "preview": "vite preview",
    "push": "npx clasp push",
    "deploy": "npm run build:all && npm run push",
    "open": "npx clasp open"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}